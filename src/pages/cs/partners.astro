---
import Layout from '../../layouts/Layout.astro';

const lang = 'cs' as const;

const partners = [
  {
    name: 'Mise HERo',
    logo: '/images/misehero-logo.png',
    description: 'je česká společnost, která vznikla s vizí využití her a herních mechanismů ve vzdělávání – představuje poutavé a zábavné vzdělávací programy pro dospělé v Evropské unii.',
  },
  {
    name: 'CPIP',
    logo: '/images/cpip-logo.png',
    description: 'Centrum pro podporu celoživotního vzdělávání (Centrul pentru Promovarea Invatarii Permanente) – CPIP je nevládní nezisková instituce působící ve vzdělávací a sociální oblasti.',
  },
  {
    name: 'Mindset Mentors',
    logo: '/images/mindset-mentors-logo.png',
    description: 'Posláním společnosti Mindset Mentors je spoluvytvářet sebevědomé týmy a společnosti. Společnosti, ve kterých lidé otevřeně komunikují, SPOLEČNĚ PRACUJÍ a dosahují úspěchu. Mindset Mentors učí ostatní, jak proměnit komunikaci v hnací sílu úspěchu. Věří, že dobrá komunikace a správné myšlení jsou základem dobře fungujících týmů a firem. Jejich služby jsou navrženy tak, aby zlepšily nejen pracovní vztahy, ale také způsob, jakým týmy přemýšlejí a řeší problémy.',
  },
  {
    name: 'Univerzita Mikoláše Romerise',
    logo: '/images/mru-logo.png',
    description: 'MRU úzce spolupracuje s více než 350 univerzitami, veřejnými a soukromými institucemi, účastní se akademických, profesních a mezisektorových sítí.',
  },
  {
    name: 'Fond sociálních inovací',
    logo: '/images/sif-logo.png',
    description: 'je nevládní organizace založená v roce 1994 v Litvě jako charitativní a podpůrný fond. S cílem zajistit rovné příležitosti pro sociálně vyloučené osoby prostřednictvím sociálních inovací a vzdělávání.',
  },
  {
    name: 'Sindicatul Polițiștilor Europeni EUROPOL',
    logo: '/images/europol-union-logo.jpg',
    description: 'je odborová organizace policistů zřízená při ministerstvu vnitra rumunské vlády. Tento odborový svaz se zasazuje o základní a profesní práva policistů a usiluje o nalezení účinné, všestranné a nezávislé alternativy ke zvýšení úrovně čestného zastoupení rumunských policistů.',
  },
];
---

<Layout title="Partneři | POLICE-COM" lang={lang}>
  <section class="page-hero">
    <div class="container">
      <span class="section-label">Konsorcium</span>
      <h1 class="section-title animate-in">PARTNERI</h1>
      <p class="section-subtitle animate-in delay-1">Konsorcium POLICE-COM sdružuje instituce z celé Evropské unie, kombinující akademické odborné znalosti s praktickými zkušenostmi z policejního vzdělávání.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="partners-grid">
        {partners.map((partner, i) => (
          <div class={`partner-card animate-in delay-${i + 1}`}>
            <div class="partner-logo">
              <img src={partner.logo} alt={`${partner.name} logo`} />
            </div>
            <h3 class="partner-name">{partner.name}</h3>
            <p class="partner-role">{partner.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero { padding: calc(72px + 4rem) 0 3rem; background: var(--color-bg-elevated); border-bottom: 1px solid var(--color-border); }
  .partners-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .partner-card { background: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: var(--radius); padding: 2rem; transition: transform 0.3s, border-color 0.3s; }
  .partner-card:hover { transform: translateY(-4px); border-color: var(--color-accent); }
  .partner-logo { margin-bottom: 1.25rem; }
  .partner-logo img { max-height: 60px; max-width: 180px; object-fit: contain; }
  .partner-name { font-size: 1.1rem; font-weight: 600; color: var(--color-text); margin-bottom: 0.75rem; line-height: 1.3; }
  .partner-role { font-size: 0.9rem; color: var(--color-text-muted); line-height: 1.6; }
  @media (max-width: 768px) { .partners-grid { grid-template-columns: 1fr; } }
</style>
