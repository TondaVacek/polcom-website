    author: 'admin',
    images: ['/images/news-romania-meeting-1.jpg', '/images/news-romania-meeting-2.jpg'],
    content: 'Zástupci partnerů konsorcia se sešli v Rumunsku na klíčové projektové schůzce. Úvodní den byl věnován školení zaměřenému na využití umělé inteligence pro generování nápadů. Partneři se rozhodli spojit své odborné znalosti při tvorbě multimediálních školicích materiálů pro šest komunikačních modulů.',
  },
  {
    title: 'Projekt POLICE COM vstupuje do provozní fáze!',
    date: 'Led 1, 2024',
    author: 'admin',
    images: ['/images/news-launch.jpg'],
    content: 'Projekt POLICE-COM byl oficiálně zahájen a sdružuje konsorcium šesti partnerů ze tří zemí EU. Projekt se zaměřuje na tvorbu školicích materiálů pro pedagogy formující novou generaci příslušníků bezpečnostních složek s klíčovými oblastmi zahrnujícími komunikaci, řešení konfliktů, deeskalaci a emoční inteligenci.',
  },
];
---

<Layout title="Novinky | POLICE-COM" lang={lang}>
  <section class="page-hero">
    <div class="container">
      <span class="section-label">{t(lang, 'news.title')}</span>
      <h1 class="section-title animate-in">Novinky a aktualizace</h1>
      <p class="section-subtitle animate-in delay-1">Sledujte nejnovější vývoj projektu POLICE-COM.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="news-list">
        {posts.map((post, i) => (
          <article class={`news-item animate-in delay-${Math.min(i + 1, 6)}`}>
            <div class="news-meta">
              <time>{post.date}</time>
              <span class="news-author">{post.author}</span>
            </div>
            <h2 class="news-title">{post.title}</h2>
            {post.images && post.images.length > 0 && (
              <div class="news-images">
                {post.images.map((img) => (
                  <img src={img} alt={post.title} class="news-image" />
                ))}
              </div>
            )}
            <p class="news-excerpt">{post.content}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero { padding: calc(72px + 4rem) 0 3rem; background: var(--color-bg-elevated); border-bottom: 1px solid var(--color-border); }
  .news-list { display: flex; flex-direction: column; }
  .news-item { padding: 2rem 0; border-bottom: 1px solid var(--color-border); }
  .news-item:first-child { padding-top: 0; }
  .news-meta { display: flex; align-items: center; gap: 1rem; margin-bottom: 0.75rem; }
  .news-meta time { font-size: 0.8rem; color: var(--color-accent); font-weight: 500; }
  .news-author { font-size: 0.8rem; color: var(--color-text-muted); }
  .news-author::before { content: '·'; margin-right: 1rem; }
  .news-title { font-family: var(--font-display); font-size: 1.5rem; font-weight: 400; color: var(--color-text); margin-bottom: 0.5rem; line-height: 1.3; }
  .news-images { display: flex; gap: 1rem; margin: 1rem 0; flex-wrap: wrap; }
  .news-image { max-width: 280px; max-height: 200px; object-fit: cover; border-radius: var(--radius-sm); border: 1px solid var(--color-border); }
  .news-excerpt { font-size: 0.95rem; color: var(--color-text-muted); line-height: 1.7; max-width: 700px; }
</style>
