---
import Layout from '../../layouts/Layout.astro';
import { t } from '../../i18n/translations';
import catalogData from '../../data/training-materials.json';

const lang = 'cs' as const;
const langCode = 'cz';

const materials = catalogData.materials.filter(m => m.language === langCode);
const modules = [...new Set(materials.map(m => m.module))].sort();
const phases = [...new Set(materials.map(m => m.phase))].sort();
const resourceTypes = [...new Set(materials.map(m => m.resourceType))].sort();
const allTopics = [...new Set(materials.flatMap(m => m.topics))].sort();
const allEquipment = [...new Set(materials.flatMap(m => m.equipment || []))].sort();
const allFormats = [...new Set(materials.flatMap(m => m.interactionFormats || []))].sort();

const moduleNames: Record<number, string> = {
  1: 'Aktivní naslouchání',
  2: 'Respektující a nediskriminační komunikace',
  3: 'Komunikace pod tlakem',
  4: 'Deeskalace a řešení konfliktů',
  5: 'Techniky vyjednávání a přesvědčování',
  6: 'Emoční inteligence v komunikaci',
};

const phaseNames: Record<string, string> = {
  '0': 'Předběžné hodnocení', '1': 'Základ', '2': 'Hloubkový ponor',
  '3': 'Pokročilá aplikace', '4': 'Reflexe a samostudium',
  '5': 'Závěr a akční plán', 'T': 'Materiály pro učitele', 'W': 'Reference',
};

const resourceTypeLabels: Record<string, string> = {
  activity: 'Aktivita', 'action-plan': 'Akční plán', assessment: 'Hodnocení', cards: 'Karty',
  'case-study': 'Případová studie', discussion: 'Diskuse', game: 'Hra', handout: 'Podklady',
  icebreaker: 'Icebreaker', image: 'Obrázek', presentation: 'Prezentace', reference: 'Reference',
  reflection: 'Reflexe', roleplay: 'Hraní rolí', scenario: 'Scénář', 'self-study': 'Samostudium',
  'teacher-guide': 'Průvodce pro učitele', theory: 'Teorie', video: 'Video', 'video-script': 'Video scénář',
};

const fileTypeIcons: Record<string, string> = { pdf: '📄', docx: '📝', pptx: '📊', mp4: '🎬', png: '🖼️' };

const uiLabels = {
  heroLabel: 'Vzdělávací materiály', heroTitle: 'Najděte výukové zdroje',
  heroSub: `Procházejte a filtrujte ${materials.length} vzdělávacích materiálů napříč všemi šesti moduly.`,
  filters: 'Filtry', clearAll: 'Vymazat vše', search: 'Hledat podle názvu...',
  module: 'Modul', phase: 'Fáze', resourceType: 'Typ', topic: 'Téma',
  materials: 'materiálů', noResults: 'Žádné materiály neodpovídají vašim filtrům.',
  downloadAll: 'Stáhnout vše', download: 'Stáhnout', close: 'Zavřít', preview: 'Náhled',
  summary: 'Shrnutí', details: 'Podrobnosti', moduleLabel: 'Modul', phaseLabel: 'Fáze',
  typeLabel: 'Typ', fileLabel: 'Soubor', topicsLabel: 'Témata',
  downloadFiltered: 'Stáhnout filtrované',
  previewNA: 'Náhled není k dispozici pro tento typ souboru. Klikněte na stáhnout pro zobrazení.',
  duration: 'Doba trvání', equipment: 'Vybavení', interactionFormat: 'Forma',
  groupSize: 'Velikost skupiny', objectives: 'Cíle',
  includeUnspecified: 'Zahrnout neuvedené',
  durationRanges: { short: '0–15 min', medium: '15–30 min', long: '30–60 min', extended: '60+ min' },
  groupSizeRanges: { pairs: 'Dvojice (2)', small: 'Malá (3–5)', medium: 'Střední (6–15)', large: 'Velká (16+)' },
  estimated: 'odhad',
};
---

<Layout title="Materiály | POLICE-COM" lang={lang}>
  <section class="page-hero">
    <div class="container">
      <span class="section-label">{uiLabels.heroLabel}</span>
      <h1 class="section-title animate-in">{uiLabels.heroTitle}</h1>
      <p class="section-subtitle animate-in delay-1">{uiLabels.heroSub}</p>
    </div>
  </section>

  <section class="section materials-section">
    <div class="container">
      <!-- Filter Bar -->
      <div class="filter-bar" id="filter-bar">
        <div class="filter-bar-row">
          <input type="text" id="search-input" placeholder={uiLabels.search} class="search-input" />
          <div class="filter-dropdown" data-filter="module">
            <button class="filter-btn" type="button">{uiLabels.module} <span class="filter-arrow">▾</span></button>
            <div class="filter-panel">
              {modules.map(m => (
                <label class="filter-option">
                  <input type="checkbox" name="module" value={String(m)} />
                  <span class="filter-check"></span>
                  <span class="filter-label">{m}. {moduleNames[m]}</span>
                </label>
              ))}
            </div>
          </div>
          <div class="filter-dropdown" data-filter="phase">
            <button class="filter-btn" type="button">{uiLabels.phase} <span class="filter-arrow">▾</span></button>
            <div class="filter-panel">
              {phases.map(p => (
                <label class="filter-option">
                  <input type="checkbox" name="phase" value={p} />
                  <span class="filter-check"></span>
                  <span class="filter-label">{phaseNames[p] || p}</span>
                </label>
              ))}
            </div>
          </div>
          <div class="filter-dropdown" data-filter="type">
            <button class="filter-btn" type="button">{uiLabels.resourceType} <span class="filter-arrow">▾</span></button>
            <div class="filter-panel">
              {resourceTypes.map(rt => (
                <label class="filter-option">
                  <input type="checkbox" name="resourceType" value={rt} />
                  <span class="filter-check"></span>
                  <span class="filter-label">{resourceTypeLabels[rt] || rt}</span>
                </label>
              ))}
            </div>
          </div>
          <div class="filter-dropdown" data-filter="topic">
            <button class="filter-btn" type="button">{uiLabels.topic} <span class="filter-arrow">▾</span></button>
            <div class="filter-panel filter-panel-scroll">
              {allTopics.map(topic => (
                <label class="filter-option">
                  <input type="checkbox" name="topic" value={topic} />
                  <span class="filter-check"></span>
                  <span class="filter-label">{topic.replace(/-/g, ' ')}</span>
                </label>
              ))}
            </div>
          </div>
          <div class="filter-dropdown" data-filter="duration">
            <button class="filter-btn" type="button">{uiLabels.duration} <span class="filter-arrow">▾</span></button>
            <div class="filter-panel">
              <label class="filter-option"><input type="checkbox" name="duration" value="short" /><span class="filter-check"></span><span class="filter-label">{uiLabels.durationRanges.short}</span></label>
              <label class="filter-option"><input type="checkbox" name="duration" value="medium" /><span class="filter-check"></span><span class="filter-label">{uiLabels.durationRanges.medium}</span></label>
              <label class="filter-option"><input type="checkbox" name="duration" value="long" /><span class="filter-check"></span><span class="filter-label">{uiLabels.durationRanges.long}</span></label>
              <label class="filter-option"><input type="checkbox" name="duration" value="extended" /><span class="filter-check"></span><span class="filter-label">{uiLabels.durationRanges.extended}</span></label>
              <label class="filter-option filter-option-muted"><input type="checkbox" name="duration-unspec" id="duration-unspecified" /><span class="filter-check"></span><span class="filter-label">{uiLabels.includeUnspecified}</span></label>
            </div>
          </div>
          <div class="filter-dropdown" data-filter="equipment">
            <button class="filter-btn" type="button">{uiLabels.equipment} <span class="filter-arrow">▾</span></button>
            <div class="filter-panel filter-panel-scroll">
              {allEquipment.map(eq => (
                <label class="filter-option">
                  <input type="checkbox" name="equipment" value={eq} />
                  <span class="filter-check"></span>
                  <span class="filter-label">{eq.replace(/-/g, ' ')}</span>
                </label>
              ))}
              <label class="filter-option filter-option-muted"><input type="checkbox" name="equip-unspec" id="equipment-unspecified" /><span class="filter-check"></span><span class="filter-label">{uiLabels.includeUnspecified}</span></label>
            </div>
          </div>
          <div class="filter-dropdown" data-filter="format">
            <button class="filter-btn" type="button">{uiLabels.interactionFormat} <span class="filter-arrow">▾</span></button>
            <div class="filter-panel">
              {allFormats.map(fmt => (
                <label class="filter-option">
                  <input type="checkbox" name="format" value={fmt} />
                  <span class="filter-check"></span>
                  <span class="filter-label">{fmt.replace(/-/g, ' ')}</span>
                </label>
              ))}
              <label class="filter-option filter-option-muted"><input type="checkbox" name="format-unspec" id="format-unspecified" /><span class="filter-check"></span><span class="filter-label">{uiLabels.includeUnspecified}</span></label>
            </div>
          </div>
          <div class="filter-dropdown" data-filter="groupsize">
            <button class="filter-btn" type="button">{uiLabels.groupSize} <span class="filter-arrow">▾</span></button>
            <div class="filter-panel">
              <label class="filter-option"><input type="checkbox" name="groupsize" value="pairs" /><span class="filter-check"></span><span class="filter-label">{uiLabels.groupSizeRanges.pairs}</span></label>
              <label class="filter-option"><input type="checkbox" name="groupsize" value="small" /><span class="filter-check"></span><span class="filter-label">{uiLabels.groupSizeRanges.small}</span></label>
              <label class="filter-option"><input type="checkbox" name="groupsize" value="medium" /><span class="filter-check"></span><span class="filter-label">{uiLabels.groupSizeRanges.medium}</span></label>
              <label class="filter-option"><input type="checkbox" name="groupsize" value="large" /><span class="filter-check"></span><span class="filter-label">{uiLabels.groupSizeRanges.large}</span></label>
              <label class="filter-option filter-option-muted"><input type="checkbox" name="gs-unspec" id="groupsize-unspecified" checked /><span class="filter-check"></span><span class="filter-label">{uiLabels.includeUnspecified}</span></label>
            </div>
          </div>
          <button class="filter-reset" id="reset-filters">{uiLabels.clearAll}</button>
        </div>
      </div>

      <!-- Results -->
      <div class="results-area">
        <div class="results-header">
          <span class="results-count" id="results-count">{materials.length} {uiLabels.materials}</span>
          <div class="results-actions">
            <button class="btn-bulk-download" id="download-filtered" title={uiLabels.downloadFiltered}>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2v8m0 0l-3-3m3 3l3-3M3 12h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {uiLabels.downloadAll}
            </button>
          </div>
        </div>
        <div class="results-grid" id="results-grid"></div>
        <div class="no-results" id="no-results" style="display:none;">
          <p>{uiLabels.noResults}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Detail Modal -->
  <div class="modal-overlay" id="modal-overlay">
    <div class="modal" id="modal">
      <button class="modal-close" id="modal-close" aria-label="Close">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M5 5l10 10M15 5L5 15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
      <div class="modal-body" id="modal-body"></div>
    </div>
  </div>
</Layout>

<script define:vars={{ materials, moduleNames, phaseNames, resourceTypeLabels, fileTypeIcons, uiLabels }}>
  const grid = document.getElementById('results-grid');
  const countEl = document.getElementById('results-count');
  const noResults = document.getElementById('no-results');
  const searchInput = document.getElementById('search-input');
  const modalOverlay = document.getElementById('modal-overlay');
  const modalBody = document.getElementById('modal-body');

  let currentFiltered = materials;

  function getCheckedValues(name) {
    return [...document.querySelectorAll(`input[name="${name}"]:checked`)].map(el => el.value);
  }

  // Dropdown toggle logic
  document.querySelectorAll('.filter-dropdown .filter-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const dropdown = btn.parentElement;
      const wasOpen = dropdown.classList.contains('open');
      document.querySelectorAll('.filter-dropdown.open').forEach(d => d.classList.remove('open'));
      if (!wasOpen) dropdown.classList.add('open');
    });
  });
  // Close dropdowns on outside click
  document.addEventListener('click', (e) => {
    if (!e.target.closest('.filter-dropdown')) {
      document.querySelectorAll('.filter-dropdown.open').forEach(d => d.classList.remove('open'));
    }
  });
  // Prevent panel clicks from closing dropdown
  document.querySelectorAll('.filter-panel').forEach(panel => {
    panel.addEventListener('click', (e) => e.stopPropagation());
  });

  function renderCard(m, index) {
    const icon = fileTypeIcons[m.fileType] || '📄';
    const topicBadges = m.topics.slice(0, 3).map(t => `<span class="tag">${t.replace(/-/g, ' ')}</span>`).join('');
    const desc = m.contentDescription || m.description || '';
    const descHtml = desc ? `<p class="card-desc">${desc}</p>` : '';
    const objSnippet = m.objectives ? `<p class="card-objectives"><strong>${uiLabels.objectives}:</strong> ${m.objectives.split('\\n').filter(l => l.trim()).join('; ').substring(0, 150)}</p>` : '';
    return `<div class="material-card" data-index="${index}" role="button" tabindex="0">
      <div class="card-top"><span class="card-module">Modul ${m.module}</span><span class="card-phase">${phaseNames[m.phase] || m.phase}</span></div>
      <h3 class="card-title">${icon} ${m.title}</h3>
      ${descHtml}
      ${objSnippet}
      <div class="card-meta"><span class="card-type">${resourceTypeLabels[m.resourceType] || m.resourceType}</span>${m.duration ? `<span class="card-duration">${m.duration}${m.durationEstimated ? ' <span class="est-badge">' + uiLabels.estimated + '</span>' : ''}</span>` : ''}<span class="card-ext">${m.fileType.toUpperCase()}</span></div>
      <div class="card-tags">${topicBadges}</div>
    </div>`;
  }

  function renderPreview(m) {
    const previewUrl = `https://pub-b33a41e64ab14f4d92f341fa4bf701bd.r2.dev/materials/${encodeURI(m.previewPath || m.path)}`;
    const ext = m.fileType;
    if (ext === 'pdf' || ext === 'docx' || ext === 'pptx') {
      return `<iframe class="preview-frame" src="${previewUrl}" title="${m.title}"></iframe>`;
    } else if (ext === 'png' || ext === 'jpg' || ext === 'jpeg') {
      return `<img class="preview-image" src="https://pub-b33a41e64ab14f4d92f341fa4bf701bd.r2.dev/materials/${encodeURI(m.path)}" alt="${m.title}" />`;
    } else if (ext === 'mp4') {
      return `<video class="preview-video" controls src="https://pub-b33a41e64ab14f4d92f341fa4bf701bd.r2.dev/materials/${encodeURI(m.path)}"></video>`;
    }
    return `<div class="preview-na"><p>${uiLabels.previewNA}</p></div>`;
  }

  function openModal(m) {
    const url = `https://pub-b33a41e64ab14f4d92f341fa4bf701bd.r2.dev/materials/${encodeURI(m.path)}`;
    const pdfUrl = `https://pub-b33a41e64ab14f4d92f341fa4bf701bd.r2.dev/materials/${encodeURI(m.previewPath || m.path)}`;
    const icon = fileTypeIcons[m.fileType] || '📄';
    const topicBadges = m.topics.map(t => `<span class="tag">${t.replace(/-/g, ' ')}</span>`).join('');

    const hasPdfVersion = m.previewPath && m.previewPath !== m.path;
    let downloadButtons = '';
    if (hasPdfVersion) {
      downloadButtons = `
        <a href="${url}" download class="btn-download btn-download-alt">${uiLabels.download} ${m.fileType.toUpperCase()}</a>
        <a href="${pdfUrl}" download class="btn-download">${uiLabels.download} PDF</a>`;
    } else {
      downloadButtons = `<a href="${url}" download class="btn-download">${uiLabels.download} ${m.fileType.toUpperCase()}</a>`;
    }

    modalBody.innerHTML = `
      <div class="modal-header-info">
        <span class="card-module">${uiLabels.moduleLabel} ${m.module}: ${moduleNames[m.module] || ''}</span>
        <span class="card-phase">${phaseNames[m.phase] || m.phase}</span>
      </div>
      <h2 class="modal-title">${icon} ${m.title}</h2>
      <div class="modal-section">
        <h4>${uiLabels.summary}</h4>
        <p>${m.contentDescription || m.description || ''}</p>
        ${m.objectives ? `<h4 style="margin-top:0.75rem">${uiLabels.objectives}</h4><ul class="modal-objectives">${m.objectives.split('\\n').filter(o => o.trim().length > 0).map(o => '<li>' + o.trim() + '</li>').join('')}</ul>` : ''}
      </div>
      <div class="modal-section">
        <h4>${uiLabels.details}</h4>
        <div class="modal-details-grid">
          <span class="detail-label">${uiLabels.typeLabel}</span><span class="detail-value"><span class="card-type">${resourceTypeLabels[m.resourceType] || m.resourceType}</span></span>
          ${m.duration ? `<span class="detail-label">${uiLabels.duration}</span><span class="detail-value">${m.duration}${m.durationEstimated ? ' <span class="est-badge">' + uiLabels.estimated + '</span>' : ''}</span>` : ''}
          ${(m.equipment && m.equipment.length) ? `<span class="detail-label">${uiLabels.equipment}</span><span class="detail-value">${m.equipment.map(e => e.replace(/-/g, ' ')).join(', ')}${m.equipmentEstimated ? ' <span class="est-badge">' + uiLabels.estimated + '</span>' : ''}</span>` : ''}
          ${(m.interactionFormats && m.interactionFormats.length) ? `<span class="detail-label">${uiLabels.interactionFormat}</span><span class="detail-value">${m.interactionFormats.map(f => f.replace(/-/g, ' ')).join(', ')}</span>` : ''}
          ${m.groupSize ? `<span class="detail-label">${uiLabels.groupSize}</span><span class="detail-value">${m.groupSize}</span>` : ''}
          <span class="detail-label">${uiLabels.fileLabel}</span><span class="detail-value">${m.fileType.toUpperCase()} (${m.filename})</span>
          <span class="detail-label">${uiLabels.topicsLabel}</span><span class="detail-value">${topicBadges}</span>
        </div>
      </div>
      <div class="modal-section">
        <h4>${uiLabels.preview}</h4>
        ${renderPreview(m)}
      </div>
      <div class="modal-actions">
        ${downloadButtons}
      </div>
    `;
    modalOverlay.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modalOverlay.classList.remove('open');
    document.body.style.overflow = '';
    modalBody.innerHTML = '';
  }

  function getDurationBucket(m) {
    if (!m.duration) return null;
    const d = parseInt(m.duration);
    if (isNaN(d)) return null;
    if (d <= 15) return 'short';
    if (d <= 30) return 'medium';
    if (d <= 60) return 'long';
    return 'extended';
  }

  function getGroupSizeBucket(m) {
    if (!m.groupSize) return null;
    const s = m.groupSize.toString();
    if (/pair/i.test(s)) return 'pairs';
    const match = s.match(/(\d+)/);
    if (!match) return null;
    const n = parseInt(match[1]);
    if (n <= 2) return 'pairs';
    if (n <= 5) return 'small';
    if (n <= 15) return 'medium';
    return 'large';
  }

  function updateDropdownBadges() {
    document.querySelectorAll('.filter-dropdown').forEach(dd => {
      const checks = dd.querySelectorAll('.filter-panel input[type="checkbox"]:checked');
      const btn = dd.querySelector('.filter-btn');
      const count = [...checks].filter(c => !c.name.includes('unspec')).length;
      const badge = btn.querySelector('.filter-badge');
      if (count > 0) {
        if (badge) { badge.textContent = count; }
        else { btn.insertAdjacentHTML('afterbegin', `<span class="filter-badge">${count}</span>`); }
        dd.classList.add('has-selection');
      } else {
        if (badge) badge.remove();
        dd.classList.remove('has-selection');
      }
    });
  }

  function applyFilters() {
    const query = searchInput.value.toLowerCase().trim();
    const selectedModules = getCheckedValues('module');
    const selectedPhases = getCheckedValues('phase');
    const selectedTypes = getCheckedValues('resourceType');
    const selectedTopics = getCheckedValues('topic');
    const selectedDurations = getCheckedValues('duration');
    const selectedEquipment = getCheckedValues('equipment');
    const selectedFormats = getCheckedValues('format');
    const selectedGroupSizes = getCheckedValues('groupsize');
    const durationUnspecified = document.getElementById('duration-unspecified').checked;
    const equipmentUnspecified = document.getElementById('equipment-unspecified').checked;
    const formatUnspecified = document.getElementById('format-unspecified').checked;
    const groupsizeUnspecified = document.getElementById('groupsize-unspecified').checked;
    currentFiltered = materials.filter(m => {
      if (query && !m.title.toLowerCase().includes(query) && !m.filename.toLowerCase().includes(query)) return false;
      if (selectedModules.length && !selectedModules.includes(String(m.module))) return false;
      if (selectedPhases.length && !selectedPhases.includes(m.phase)) return false;
      if (selectedTypes.length && !selectedTypes.includes(m.resourceType)) return false;
      if (selectedTopics.length && !selectedTopics.some(t => m.topics.includes(t))) return false;

      if (selectedDurations.length) {
        const bucket = getDurationBucket(m);
        if (!bucket) { if (!durationUnspecified) return false; }
        else if (!selectedDurations.includes(bucket)) return false;
      }

      if (selectedEquipment.length) {
        const eq = m.equipment || [];
        if (eq.length === 0) { if (!equipmentUnspecified) return false; }
        else if (!selectedEquipment.some(e => eq.includes(e))) return false;
      }

      if (selectedFormats.length) {
        const fmts = m.interactionFormats || [];
        if (fmts.length === 0) { if (!formatUnspecified) return false; }
        else if (!selectedFormats.some(f => fmts.includes(f))) return false;
      }

      if (selectedGroupSizes.length) {
        const bucket = getGroupSizeBucket(m);
        if (!bucket) { if (!groupsizeUnspecified) return false; }
        else if (!selectedGroupSizes.includes(bucket)) return false;
      }

      return true;
    });

    grid.innerHTML = currentFiltered.map((m, i) => renderCard(m, i)).join('');
    countEl.textContent = `${currentFiltered.length} ${uiLabels.materials}`;
    noResults.style.display = currentFiltered.length === 0 ? 'block' : 'none';
    grid.style.display = currentFiltered.length === 0 ? 'none' : '';

    grid.querySelectorAll('.material-card').forEach(card => {
      card.addEventListener('click', () => {
        const idx = parseInt(card.dataset.index);
        openModal(currentFiltered[idx]);
      });
      card.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); card.click(); }
      });
    });

    updateDropdownBadges();
  }

  applyFilters();
  searchInput.addEventListener('input', applyFilters);
  document.querySelectorAll('.filter-panel input[type="checkbox"]').forEach(cb => cb.addEventListener('change', applyFilters));
  document.getElementById('reset-filters').addEventListener('click', () => {
    searchInput.value = '';
    document.querySelectorAll('.filter-panel input[type="checkbox"]').forEach(cb => cb.checked = false);
    document.getElementById('groupsize-unspecified').checked = true;
    applyFilters();
  });

  // Modal close
  document.getElementById('modal-close').addEventListener('click', closeModal);
  modalOverlay.addEventListener('click', (e) => { if (e.target === modalOverlay) closeModal(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

  // Bulk download
  document.getElementById('download-filtered').addEventListener('click', () => {
    if (currentFiltered.length === 0) return;
    if (currentFiltered.length > 50) {
      if (!confirm(`Tím se zahájí stahování ${currentFiltered.length} souborů. Pokračovat?`)) return;
    }
    currentFiltered.forEach((m, i) => {
      setTimeout(() => {
        const a = document.createElement('a');
        a.href = `https://pub-b33a41e64ab14f4d92f341fa4bf701bd.r2.dev/materials/${encodeURI(m.path)}`;
        a.download = m.filename;
        a.style.display = 'none';
        document.body.appendChild(a);
