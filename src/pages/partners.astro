---
import Layout from '../layouts/Layout.astro';
import { defaultLang } from '../i18n/translations';

const lang = defaultLang;

const partners = [
  {
    name: 'Mise HERo',
    country: 'Czech Republic',
    logo: '/images/misehero-logo.png',
    role: 'is a Czech company formed with the vision of using games and game mechanics in Education – presenting immersive & enjoyable training programs for adults in the European Union',
  },
  {
    name: 'CPIP',
    country: 'Romania',
    logo: '/images/cpip-logo.png',
    role: 'The Center for promoting lifelong learning (Centrul pentru Promovarea Invatarii Permanente) – CPIP is a non-governmental, non-profit institution active in the educational and social field.',
  },
  {
    name: 'Mindset Mentors',
    country: 'Czech Republic',
    logo: '/images/mindset-mentors-logo.png',
    role: "Mindset Mentors' mission is to co-create confident teams and companies. Companies where people communicate openly, WORK TOGETHER and achieve success. Mindset Mentors teach others how to turn communication into a driver of success. They believe that good communication and the right mindset are the foundation of well-functioning teams and companies. Their services are designed to improve not only working relationships, but also the way the teams think and solve problems.",
  },
  {
    name: 'Mikolas Romeris University',
    country: 'Lithuania',
    logo: '/images/mru-logo.png',
    role: 'MRU cooperates closely with over 350 universities, public and private institutions, takes part in academic, professional and inter-sectorial networks.',
  },
  {
    name: 'Social Innovation Fund',
    country: 'Lithuania',
    logo: '/images/sif-logo.png',
    role: 'is a non-governmental organization founded in 1994 in Lithuania as a charity and support fund. To ensure equal opportunities for socially excluded persons through social innovation and education.',
  },
  {
    name: 'Sindicatul Polițiștilor Europeni EUROPOL',
    country: 'Romania',
    logo: '/images/europol-union-logo.jpg',
    role: 'is a trade union organization of police officers established under the Ministry of Internal Affairs of the Government of Romania. This trade union stands up for the basic and professional rights of the police officers and seeks to find an efficient, versatile, and independent alternative to increase the level of honest representation of Romanian police officers.',
  },
];
---

<Layout title="Partners | POLICE-COM" lang={lang}>
  <section class="page-hero">
    <div class="container">
      <span class="section-label">Consortium</span>
      <h1 class="section-title animate-in">Partners</h1>
      <p class="section-subtitle animate-in delay-1">The POLICE-COM consortium brings together institutions from across the European Union, combining academic expertise with practical law enforcement training experience.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="partners-grid">
        {partners.map((partner, i) => (
          <div class={`partner-card animate-in delay-${i + 1}`}>
            <div class="partner-logo">
              <img src={partner.logo} alt={`${partner.name} logo`} />
            </div>
            <h3 class="partner-name">{partner.name}</h3>
            <span class="partner-country">{partner.country}</span>
            <p class="partner-role">{partner.role}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    padding: calc(72px + 4rem) 0 3.5rem;
    background: var(--color-bg-elevated);
    border-bottom: 1px solid var(--color-border);
  }

  .partners-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .partner-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 2rem;
    transition: transform 0.3s, border-color 0.3s, box-shadow 0.3s;
  }

  .partner-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-accent);
    box-shadow: 0 8px 24px rgba(27, 58, 107, 0.08);
  }

  .partner-logo {
    height: 60px;
    margin-bottom: 1.25rem;
    display: flex;
    align-items: center;
  }

  .partner-logo img {
    max-height: 60px;
    max-width: 160px;
    object-fit: contain;
  }

  .partner-name {
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.35rem;
    line-height: 1.3;
  }

  .partner-country {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .partner-role {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .partners-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .partners-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
