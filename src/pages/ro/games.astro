---
import Layout from '../../layouts/Layout.astro';
import { t } from '../../i18n/translations';

const lang = 'ro' as const;
---

<Layout title="Jocuri | POLICE-COM" lang={lang}>
  <section class="page-hero">
    <div class="container">
      <span class="section-label">{t(lang, 'nav.games')}</span>
      <h1 class="section-title animate-in">Jocuri de instruire</h1>
      <p class="section-subtitle animate-in delay-1">Jocuri interactive concepute pentru a dezvolta abilitățile de comunicare și dezescaladare pentru profesioniștii din domeniul aplicării legii.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="games-grid">
        <a href="/de-escalation-game/" class="game-card animate-in delay-1">
          <div class="game-icon">🎮</div>
          <h2 class="game-title">Jocul de instruire in dezescaladare</h2>
          <p class="game-desc">O simulare interactiva in care navigați prin scenarii de dialog ramificate, luand decizii care afecteaza rezultatele. Exersați tehnici de dezescaladare in situații realiste cu feedback imediat.</p>
          <div class="game-meta">
            <span>14 scenarii</span>
            <span>4 limbi</span>
            <span>Interactiv</span>
          </div>
          <span class="game-cta">Jucați acum &rarr;</span>
        </a>

        <a href="/hot-call/" class="game-card animate-in delay-2">
          <div class="game-icon">🃏</div>
          <h2 class="game-title">Hot Call — Joc de carti</h2>
          <p class="game-desc">Un joc de carti bazat pe scenarii, conceput pentru a antrena comunicarea in acțiune. Trageți carti de situație, escaladare și dezescaladare pentru a exersa luarea deciziilor sub presiune. Disponibil online și ca varianta imprimabila.</p>
          <div class="game-meta">
            <span>90 carti pe limba</span>
            <span>4 limbi</span>
            <span>Joc de carti</span>
          </div>
          <span class="game-cta">Jucați acum &rarr;</span>
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero { padding: calc(72px + 4rem) 0 3.5rem; background: var(--color-bg-elevated); border-bottom: 1px solid var(--color-border); }
  .games-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(340px, 1fr)); gap: 2rem; }
  .game-card { display: flex; flex-direction: column; padding: 2.5rem; background: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: var(--radius); transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s; text-decoration: none; color: inherit; }
  .game-card:hover { border-color: var(--color-accent); box-shadow: 0 12px 32px rgba(27,58,107,0.1); transform: translateY(-3px); }
  .game-icon { font-size: 2.5rem; margin-bottom: 1.5rem; width: 56px; height: 56px; display: flex; align-items: center; justify-content: center; background: var(--color-accent-glow); border-radius: var(--radius-sm); }
  .game-title { font-family: var(--font-display); font-size: 1.4rem; font-weight: 500; color: var(--color-text); margin-bottom: 0.75rem; }
  .game-desc { font-size: 0.95rem; color: var(--color-text-muted); line-height: 1.7; flex: 1; }
  .game-meta { display: flex; gap: 1rem; margin-top: 1.5rem; padding-top: 1.25rem; border-top: 1px solid var(--color-border); flex-wrap: wrap; }
  .game-meta span { font-size: 0.78rem; color: var(--color-accent); font-weight: 500; background: var(--color-accent-glow); padding: 0.15rem 0.6rem; border-radius: 100px; }
  .game-cta { margin-top: 1.25rem; font-size: 0.9rem; font-weight: 600; color: var(--color-accent); transition: color 0.2s; }
  .game-card:hover .game-cta { color: var(--color-accent-light); }
  @media (max-width: 560px) { .games-grid { grid-template-columns: 1fr; } }
</style>
