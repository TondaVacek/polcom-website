---
import Layout from '../../layouts/Layout.astro';
import { t } from '../../i18n/translations';

const lang = 'lt' as const;

const partners = [
  {
    name: 'Mise HERo',
    country: 'Čekija',
    logo: '/images/misehero-logo.png',
    role: 'yra Čekijos įmonė, kurios pagrindinis tikslas – naudoti žaidimus ir žaidimų techniką švietime, rengiant įtraukiančias ir patrauklias mokymo programas skirtas suaugusiesiems Europos Sąjungoje.',
  },
  {
    name: 'CPIP',
    country: 'Rumunija',
    logo: '/images/cpip-logo.png',
    role: 'Mokymosi visą gyvenimą skatinimo centras (Centrul pentru Promovarea Invatarii Permanente) – CPIP yra nevyriausybinė, ne pelno siekianti organizacija, veikianti švietimo ir socialinėje srityse.',
  },
  {
    name: 'Mindset Mentors',
    country: 'Čekija',
    logo: '/images/mindset-mentors-logo.png',
    role: '„Mindset Mentors" misija – kartu kurti pasitikinčias komandas ir įmones. Įmones, kuriose žmonės atvirai bendrauja, dirba kartu ir pasiekia sėkmę. „Mindset Mentors" moko kitus, kaip bendravimą paversti sėkmės varikliu. Jie tiki, kad geras bendravimas ir tinkamas mąstymas yra gerai veikiančių komandų ir įmonių pagrindas. Jų paslaugos skirtos ne tik darbiniams santykiams, bet ir komandų mąstymui bei problemų sprendimui gerinti.',
  },
  {
    name: 'Mykolo Romerio universitetas',
    country: 'Lietuva',
    logo: '/images/mru-logo.png',
    role: 'MRU glaudžiai bendradarbiauja su daugiau nei 350 universitetų, valstybinių ir privačių institucijų, priklauso akademiniams, profesiniams ir tarpsektoriniams tinklams.',
  },
  {
    name: 'Socialinių inovacijų fondas',
    country: 'Lietuva',
    logo: '/images/sif-logo.png',
    role: 'yra nevyriausybinė organizacija, įkurta 1994 m. Lietuvoje kaip labdaros ir paramos fondas. Užtikrinti lygias galimybes socialinę atskirtį patiriantiems asmenims per socialines inovacijas ir švietimą.',
  },
  {
    name: 'Sindicatul Polițiștilor Europeni EUROPOL',
    country: 'Rumunija',
    logo: '/images/europol-union-logo.jpg',
    role: 'yra policijos pareigūnų profesinė sąjunga, įsteigta prie Rumunijos vyriausybės Vidaus reikalų ministerijos. Ši profesinė sąjunga gina pagrindines ir profesines policijos pareigūnų teises ir siekia rasti veiksmingą, įvairiapusišką ir nepriklausomą alternatyvą, kad padidintų Rumunijos policijos pareigūnų sąžiningo atstovavimo lygį.',
  },
];
---

<Layout title="Partneriai | POLICE-COM" lang={lang}>
  <section class="page-hero">
    <div class="container">
      <span class="section-label">Konsorciumas</span>
      <h1 class="section-title animate-in">PARTNERIAI</h1>
      <p class="section-subtitle animate-in delay-1">POLICE-COM konsorciumas suburia institucijas iš visos Europos Sąjungos, derinančias akademinę patirtį su praktine teisėsaugos mokymo patirtimi.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="partners-grid">
        {partners.map((partner, i) => (
          <div class={`partner-card animate-in delay-${i + 1}`}>
            <div class="partner-logo">
              <img src={partner.logo} alt={`${partner.name} logotipas`} />
            </div>
            <h3 class="partner-name">{partner.name}</h3>
            <span class="partner-country">{partner.country}</span>
            <p class="partner-role">{partner.role}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    padding: calc(72px + 4rem) 0 3.5rem;
    background: var(--color-bg-elevated);
    border-bottom: 1px solid var(--color-border);
  }

  .partners-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .partner-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 2rem;
    transition: transform 0.3s, border-color 0.3s, box-shadow 0.3s;
  }

  .partner-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-accent);
    box-shadow: 0 8px 24px rgba(27,58,107,0.08);
  }

  .partner-logo {
    height: 60px;
    margin-bottom: 1.25rem;
    display: flex;
    align-items: center;
  }

  .partner-logo img {
    max-height: 60px;
    max-width: 160px;
    object-fit: contain;
  }

  .partner-name {
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.35rem;
    line-height: 1.3;
  }

  .partner-country {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .partner-role {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .partners-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .partners-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
