---
import { t, type Lang } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<footer class="footer">
  <div class="container">
    <div class="footer-eu">
      <div class="eu-flag">
        <svg width="48" height="32" viewBox="0 0 48 32" fill="none">
          <rect width="48" height="32" rx="2" fill="#003399"/>
          {[...Array(12)].map((_, i) => {
            const angle = (i * 30 - 90) * Math.PI / 180;
            const cx = 24 + 10 * Math.cos(angle);
            const cy = 16 + 10 * Math.sin(angle);
            return <polygon points={`${cx},${cy-2.5} ${cx+0.9},${cy-0.8} ${cx+2.4},${cy-0.8} ${cx+1.2},${cy+0.3} ${cx+1.5},${cy+2} ${cx},${cy+1} ${cx-1.5},${cy+2} ${cx-1.2},${cy+0.3} ${cx-2.4},${cy-0.8} ${cx-0.9},${cy-0.8}`} fill="#FFCC00"/>;
          })}
        </svg>
      </div>
      <p class="eu-disclaimer">{t(lang, 'footer.funding')}</p>
    </div>

    <div class="footer-bottom">
      <p class="footer-copy">{t(lang, 'footer.rights')}</p>
      <a href="https://www.facebook.com/people/Police-COM/61560171684268/" class="footer-social" target="_blank" rel="noopener">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
        </svg>
      </a>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-bg-elevated);
    border-top: 1px solid var(--color-border);
    padding: 3.5rem 0 2.5rem;
    margin-top: auto;
  }

  .footer-eu {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    padding-bottom: 2rem;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .eu-flag {
    flex-shrink: 0;
    margin-top: 2px;
  }

  .eu-disclaimer {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    max-width: 720px;
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-copy {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .footer-social {
    color: var(--color-text-muted);
    transition: color 0.2s;
  }

  .footer-social:hover {
    color: var(--color-accent-light);
  }

  @media (max-width: 640px) {
    .footer-eu {
      flex-direction: column;
    }
  }
</style>
